{
  "name": "euther-oxide-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/write-build-info.mjs && vite",
    "dev:bridge": "bash scripts/dev-bridge.sh",
    "dev:bridge:release": "EUTHER_BRIDGE_RELEASE=1 bash scripts/dev-bridge.sh",
    "build:euthercivet": "bash scripts/build-euthercivet-web.sh",
    "android:eutherlist": "bash scripts/eutherlist-release-apk.sh",
    "dev:eutherbooks-player": "npm --prefix apps/eutherbooks-player run dev",
    "build:eutherbooks-player": "npm --prefix apps/eutherbooks-player run build",
    "tauri:eutherbooks-player": "npm --prefix apps/eutherbooks-player run tauri",
    "android:eutherbooks-player": "bash scripts/eutherbooks-player-release-apk.sh",
    "android:euthersync": "bash scripts/euthersync-release-apk.sh",
    "android:release-apks": "bash scripts/android-release-apks.sh",
    "build:release": "bash scripts/build-release.sh",
    "build:all": "bash scripts/build-all.sh",
    "build": "node scripts/write-build-info.mjs && npm run build:euthercivet && tsc && vite build",
    "preview": "vite preview",
    "tauri:run": "bash scripts/run-tauri-release.sh",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/three": "^0.184.1",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
