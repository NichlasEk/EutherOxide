{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EutherList",
  "version": "0.1.0",
  "identifier": "com.nichlasek.eutherlist",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5181",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EutherList",
        "width": 430,
        "height": 860,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
