{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EutherBooks Player",
  "version": "0.1.10",
  "identifier": "com.nichlasek.eutherbooksplayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5183",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EutherBooks Player",
        "width": 430,
        "height": 860,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
